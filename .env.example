# Renderer (Vite / Electron)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Edge Functions (local)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Browser (Playwright CDP)
# Optional. If unset, Skynul will try to auto-detect a system Chrome/Chromium.
# Use an ABSOLUTE path to the browser executable.
# Examples (Linux): /usr/bin/google-chrome, /usr/bin/chromium, /var/lib/snapd/snap/bin/chromium
SKYNUL_CHROME_PATH=
