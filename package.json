{
  "name": "skynul",
  "version": "0.1.0-alpha.28",
  "description": "Skynul - local-first desktop agent with explicit permissions",
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "author": "Skynul",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jay-south/skynul.git"
  },
  "homepage": "https://example.com",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm -s typecheck:node && pnpm -s typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm -s typecheck && electron-vite build",
    "pack:prepare": "node scripts/prepare-packaging.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --dir",
    "build:win": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --win --publish never",
    "build:mac": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --mac --publish never",
    "build:linux": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --linux --publish never",
    "release:win": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --win --publish always",
    "release:mac": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --mac --publish always",
    "release:linux": "pnpm -s build && pnpm -s pack:prepare && node scripts/run-electron-builder.mjs --linux --publish always",
    "release:cut": "node scripts/cut-release.mjs",
    "release:cut:push": "node scripts/cut-release.mjs --push"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@polymarket/clob-client": "^5.2.4",
    "@slack/bolt": "^4.6.0",
    "@supabase/supabase-js": "^2.97.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "electron-updater": "^6.8.3",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.40.1",
    "playwright-core": "^1.58.2",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "puppeteer"
    ]
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
