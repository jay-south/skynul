node-linker=hoisted

# Some tooling (electron-builder) still assumes an npm-like node_modules structure.
# This forces pnpm to create additional hoisted/symlinked layout that those tools
# can traverse when collecting production dependencies.
shamefully-hoist=true

# Electron packaging (electron-builder) can break with pnpm's default isolated linker
# because it relies on symlinks into the virtual store. Hoisted node_modules avoids
# missing runtime deps like util-deprecate on Windows.
